# =============================================================
# LegacyGraph 部署环境变量模板
# 复制此文件为 .env 并填写真实值：cp .env.example .env
# =============================================================

# ---- 端口映射 ----
BACKEND_PORT=8080
FRONTEND_PORT=80

# ---- PostgreSQL（外部服务器）----
POSTGRES_URL=jdbc:postgresql://db.example.com:5432/legacy_graph
POSTGRES_USERNAME=legacy_graph_user
POSTGRES_PASSWORD=your_postgres_password

# ---- Neo4j（外部服务器）----
NEO4J_URI=bolt://neo4j.example.com:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ---- Redis（外部服务器）----
REDIS_HOST=redis.example.com
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ---- MinIO / S3（外部服务器）----
MINIO_ENDPOINT=http://minio.example.com:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key

# ---- LLM（可选，也可从数据库 lg_llm_provider 表读取）----
OPENAI_API_KEY=
