package io.github.legacygraph.agent;

// ReviewRequest, ReviewResult, Recommendation are inner classes of ReviewAgent,
// accessible directly since this test is in the same package
import io.github.legacygraph.llm.LlmGateway;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.junit.jupiter.api.extension.ExtendWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.jupiter.MockitoExtension;

import java.util.List;
import java.util.Map;

import static org.junit.jupiter.api.Assertions.*;
import static org.mockito.ArgumentMatchers.*;
import static org.mockito.Mockito.*;

/**
 * ReviewAgent 单元测试
 */
@ExtendWith(MockitoExtension.class)
class ReviewAgentTest {

    @Mock
    private LlmGateway llmGateway;

    @InjectMocks
    private ReviewAgent reviewAgent;

    private ReviewRequest request;

    @BeforeEach
    void setUp() {
        request = new ReviewRequest();
        request.setProjectId("project-1");
        request.setTargetType("NODE");
        request.setTargetDescription("API endpoint: POST /api/users");
        request.setSupportingEvidence(List.of(
                "Source code scan found the controller method",
                "Test result shows 200 response"
        ));
        request.setConflictingEvidence(List.of(
                "No corresponding frontend route found"
        ));
        request.setCurrentConfidence(0.75);
    }

    @Test
    void testGenerateReviewSuggestion_Approved() {
        // given
        ReviewResult mockResult = new ReviewResult();
        mockResult.setSummary("The node appears valid and should be approved");
        mockResult.setSupportingPoints(List.of(
                "Source code confirms the endpoint exists",
                "Test result confirms the endpoint works"
        ));
        mockResult.setConflictingPoints(List.of(
                "Missing frontend route is likely a different concern"
        ));
        mockResult.setRecommendation(Recommendation.APPROVE);
        mockResult.setReasoning("Two independent evidence sources confirm the endpoint; the missing route is a frontend-only gap.");

        when(llmGateway.callWithTemplate(
                eq("project-1"),
                eq("graph-merge-decision"),
                any(Map.class),
                eq(ReviewResult.class)
        )).thenReturn(mockResult);

        // when
        ReviewResult result = reviewAgent.generateReviewSuggestion(request);

        // then
        assertNotNull(result);
        assertEquals(Recommendation.APPROVE, result.getRecommendation());
        assertEquals("The node appears valid and should be approved", result.getSummary());
        assertEquals(2, result.getSupportingPoints().size());
        assertEquals(1, result.getConflictingPoints().size());
        assertFalse(result.getReasoning().isEmpty());

        // Verify LLM was called with correct template and variables
        verify(llmGateway, times(1)).callWithTemplate(
                eq("project-1"),
                eq("graph-merge-decision"),
                any(Map.class),
                eq(ReviewResult.class)
        );
    }

    @Test
    void testGenerateReviewSuggestion_Rejected() {
        // given
        ReviewResult mockResult = new ReviewResult();
        mockResult.setSummary("The node should be rejected due to insufficient evidence");
        mockResult.setSupportingPoints(List.of());
        mockResult.setConflictingPoints(List.of(
                "No source code references this endpoint",
                "Not found in any test result",
                "Documentation does not mention it"
        ));
        mockResult.setRecommendation(Recommendation.REJECT);
        mockResult.setReasoning("All three evidence categories are empty; the candidate appears to be a false positive.");

        when(llmGateway.callWithTemplate(
                anyString(),
                eq("graph-merge-decision"),
                any(Map.class),
                eq(ReviewResult.class)
        )).thenReturn(mockResult);

        // when
        ReviewResult result = reviewAgent.generateReviewSuggestion(request);

        // then
        assertNotNull(result);
        assertEquals(Recommendation.REJECT, result.getRecommendation());
        assertEquals(0, result.getSupportingPoints().size());
        assertEquals(3, result.getConflictingPoints().size());
        assertNotNull(result.getReasoning());
    }

    @Test
    void testGenerateReviewSuggestion_NeedMoreInfo() {
        // given
        ReviewResult mockResult = new ReviewResult();
        mockResult.setSummary("Cannot determine; more information needed");
        mockResult.setSupportingPoints(List.of(
                "Parsed from source code"
        ));
        mockResult.setConflictingPoints(List.of(
                "Confidence is below threshold"
        ));
        mockResult.setRecommendation(Recommendation.NEED_MORE_INFO);
        mockResult.setReasoning("Only one piece of supporting evidence vs one conflicting. Manual review is required to resolve.");

        when(llmGateway.callWithTemplate(
                anyString(),
                eq("graph-merge-decision"),
                any(Map.class),
                eq(ReviewResult.class)
        )).thenReturn(mockResult);

        // when
        ReviewResult result = reviewAgent.generateReviewSuggestion(request);

        // then
        assertNotNull(result);
        assertEquals(Recommendation.NEED_MORE_INFO, result.getRecommendation());
        assertNotNull(result.getSummary());
        assertNotNull(result.getReasoning());
    }

    @Test
    void testGenerateReviewSuggestion_PassesCorrectVariables() {
        // given — verify the LLM call receives properly formatted variables
        ReviewResult mockResult = new ReviewResult();
        mockResult.setSummary("ok");
        mockResult.setRecommendation(Recommendation.APPROVE);
        mockResult.setReasoning("good");

        when(llmGateway.callWithTemplate(
                eq("project-1"),
                eq("graph-merge-decision"),
                any(Map.class),
                eq(ReviewResult.class)
        )).thenAnswer(invocation -> {
            // Capture the variables map sent to LLM
            Map<String, String> vars = invocation.getArgument(2);
            assertEquals("NODE", vars.get("targetType"));
            assertEquals("API endpoint: POST /api/users", vars.get("targetDescription"));
            assertTrue(vars.get("supportingEvidence").contains("controller method"));
            assertTrue(vars.get("conflictingEvidence").contains("frontend route"));
            assertEquals("0.75", vars.get("currentConfidence"));
            return mockResult;
        });

        // when
        ReviewResult result = reviewAgent.generateReviewSuggestion(request);

        // then
        assertNotNull(result);
        verify(llmGateway, times(1)).callWithTemplate(
                eq("project-1"),
                eq("graph-merge-decision"),
                any(Map.class),
                eq(ReviewResult.class)
        );
    }
}
